# SparkContext Challenges:
# - Low-level, not developer friendly
# - Multi-user conflicts → resource contention

# SparkSession Benefits:
# - Catalyst Optimizer: predicate pushdown, column pruning, join reordering
# - Better concurrency and resource isolation


# ============================================================
# 2. PROGRAMMING CONSTRUCTS (EVOLUTION)
# ============================================================
# RDD        → Spark 1.x | Low-level | No optimization | Manual code
# DataFrame  → Spark 1.3 | High-level | Catalyst + Tungsten | No compile-time type safety
# Dataset    → Spark 1.6 | High-level | Compile-time safety | Seamless RDD conversion

# In Spark 2.x: DataFrame + Dataset merged → Unified Structured API
# DataFrame = Dataset[Row]

# DataFrame Challenges:
# - No type safety (errors caught at runtime, not compile time)
# - No lambda functions
# - df.rdd conversion loses Catalyst + Tungsten optimization

# Dataset Fixes:
# - Compile-time type safety
# - Flexible low-level code
# - RDD conversion is seamless (no optimization loss)

# Execution Flow:
# DF/DS code → runs on Driver → compiled to RDD → sent to Executors
# Raw RDD   → goes directly to Executors (no optimization)


# ============================================================
# 3. SCHEMA OPTIONS
# ============================================================
# 1. INFER    → inferSchema=true (reads first ~100 rows, NOT for production)
# 2. IMPLICIT → Parquet/Avro (schema embedded in file)
# 3. EXPLICIT → Manual definition (recommended for production)

# --- Programmatic Schema ---
from pyspark.sql.types import StructType, StructField, StringType, IntegerType, DoubleType
# StructType = full row | StructField = each column | 3rd param = nullable
schema = StructType([
    StructField("id",     IntegerType(), True),
    StructField("name",   StringType(),  True),
    StructField("age",    IntegerType(), True),
    StructField("salary", DoubleType(),  True)
])
df = spark.read.schema(schema).csv("path", header=True)

# --- DDL String Schema (uses SQL types) ---
schema_ddl = "id INT, name STRING, age INT, salary DOUBLE"
df = spark.read.schema(schema_ddl).csv("path", header=True)

# Spark vs Scala Type Mapping:
# int       → IntegerType
# Long      → LongType
# date      → DateType
# float     → FloatType
# double    → DoubleType
# timestamp → TimestampType


# ============================================================
# 4. READING DATA
# ============================================================

# --- CSV ---
df = (spark.read
    .option("header",      "true")
    .option("inferSchema", "true")
    .option("sep",         "|")
    .option("mode",        "DROPMALFORMED")
    .csv("hdfs://path/file.csv"))

# Reading Modes:
# PERMISSIVE   (default) → sets fields to NULL, stores bad row in _corrupt_record
# DROPMALFORMED          → silently ignores bad rows
# FAILFAST               → throws exception on first bad row

# --- Parquet (schema embedded in file, no inferSchema needed) ---
df = (spark.read
    .option("mergeSchema",       "true")   # handle schema evolution
    .option("recursiveFileLookup","true")  # read all subdirectories
    .parquet("hdfs://path/parquet_dir"))

# --- JDBC (MySQL) ---
jdbc_url   = "jdbc:mysql://localhost:3306/mydb"
properties = {
    "user":     "root",
    "password": "mypassword",
    "driver":   "com.mysql.cj.jdbc.Driver"
}
df = spark.read.jdbc(url=jdbc_url, table="employee", properties=properties)

# --- View Data ---
df.show()       # displays top 20 rows (lazy → triggers action)
df.collect()    # returns all rows as Python list (use carefully on large data)
df.printSchema()


# ============================================================
# 5. WRITING DATA
# ============================================================

# Basic Write
df.write.format("csv").mode("overwrite").option("maxRecordsPerFile", 10000).save("path")

# Shortcuts
df.write.csv("path")
df.write.json("path")
df.write.parquet("path")
df.write.orc("path")

# Write Modes:
# overwrite          → replace existing data
# append             → add to existing data
# ignore             → skip if path exists
# error/errorifexists→ fail if path exists (DEFAULT)


# ============================================================
# 6. FILE LAYOUT CONTROL
# ============================================================
# Note: Number of output files = Number of partitions in DataFrame

# Repartition → INCREASE partitions (increases parallelism, causes full shuffle)
df.repartition(10).write.mode("overwrite").parquet("output/parquet")

# Coalesce → REDUCE partitions (minimizes shuffle, avoids full re-partition)
df.coalesce(1).write.mode("overwrite").csv("output/single_file", header=True)

# PartitionBy → Hive-style folder partitioning (enables partition pruning)
df.write.partitionBy("year", "month").parquet("path/output")
# Output structure:
# year=2025/month=01/*.parquet
# year=2025/month=02/*.parquet

# BucketBy + SortBy (requires Hive support)
df.write.partitionBy("year", "month") \
        .bucketBy(4, "id") \
        .sortBy("name") \
        .saveAsTable("bucketed_table")

# MaxRecordsPerFile → control file size
df.write.option("maxRecordsPerFile", 10000).parquet("output/path")

# Save vs SaveAsTable
df.repartition(10).write.format("parquet").mode("overwrite").save("output/parquet")         # path-based
df.repartition(10).write.format("parquet").mode("overwrite").saveAsTable("output/parquet")  # Hive table


