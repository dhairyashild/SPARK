 11. RDD WORD COUNT (Python)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

 from pyspark import SparkContext
 sc = SparkContext("local", "WordCount")

 word_count = (
     sc.textFile("data.txt")
     .flatMap(lambda line: line.split(" "))  # lines → words
     .map(lambda word: (word, 1))            # word → (word,1)
     .reduceByKey(lambda a, b: a + b)        # aggregate counts
 )
 word_count.collect()  # ACTION → triggers execution
 # Output: [('hello', 3), ('spark', 2)]

