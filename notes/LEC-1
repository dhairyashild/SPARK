 15. JOINS IN SPARK
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 df1.join(df2, df1.id == df2.id, "inner")

# Join Types:
  inner | left/left_outer | right/right_outer
  full  | left_semi (no right cols) | left_anti | cross

# Ambiguity Fix:
  .withColumnRenamed("old","new")   # rename before join
  .drop(df2["id"])                  # drop after join

# Null Handling:
  .withColumn("col", expr("coalesce(order_id, -1)"))

