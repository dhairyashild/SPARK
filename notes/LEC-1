 12. READING DATA IN SPARK
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CSV
 df = (spark.read
     .option("header", "true")
     .option("inferSchema", "true")   # NOT for production
     .option("sep", "|")
     .option("mode", "DROPMALFORMED")
     .csv("hdfs://path/file.csv"))

# Read Modes:
  PERMISSIVE    → NULL for corrupt fields, adds _corrupt_record column (default)
  DROPMALFORMED → Ignores corrupt records
  FAILFAST      → Throws exception on corrupt record

# Schema Options:
  1. INFER    → inferSchema=true (reads N records first → slow, avoid in prod)
  2. IMPLICIT → Parquet/Avro carry schema in file
  3. EXPLICIT → Define manually (BEST for production)

# Explicit Schema - Programmatic
 from pyspark.sql.types import StructType, StructField, StringType, IntegerType
 schema = StructType([
     StructField("id",   IntegerType(), True),
     StructField("name", StringType(),  True)
 ])
 df = spark.read.schema(schema).csv("path", header=True)

# Explicit Schema - DDL (simpler)
 schema = "id INT, name STRING, salary DOUBLE"
 df = spark.read.schema(schema).csv("path", header=True)

# Parquet (schema embedded in file)
 df = spark.read.option("mergeSchema","true").parquet("path/")

# JDBC
 df = spark.read.jdbc(
     url="jdbc:mysql://localhost:3306/mydb",
     table="employee",
     properties={"user":"root","password":"pwd",
                 "driver":"com.mysql.cj.jdbc.Driver"})

