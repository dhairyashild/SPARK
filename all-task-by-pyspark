""")

# ==================== 7. OPTIONAL: Performance optimization ====================
# Repartition for parallelism
df = df.repartition(50, col("partition_key"))

# Coalesce for reducing partitions (no shuffle)
df = df.coalesce(10)

# Hint for optimizations
agg_df = agg_df.hint("broadcast") \
    .join(other_df, "key", "inner")

# ==================== COMPLETE END-TO-END EXAMPLE ====================
# Read raw
raw_df = spark.read.parquet("s3://raw/sales/")

# Clean
clean_df = raw_df.dropDuplicates(["order_id"]) \
    .filter("order_status == 'completed'") \
    .withColumn("order_date", col("timestamp").cast("date")) \
    .drop("raw_timestamp", "temp_column")

# Enrich
enriched_df = clean_df.join(customers_df, "customer_id", "left") \
    .join(broadcast(products_df), "product_id", "left") \
    .withColumn("total_amount", col("quantity") * col("price")) \
    .withColumn("customer_segment", 
        when(col("total_spend") > 10000, "Premium")
        .when(col("total_spend") > 5000, "Gold")
        .otherwise("Standard"))

# Aggregate
daily_sales = enriched_df.groupBy("order_date", "category", "customer_segment").agg(
    count("order_id").alias("order_count"),
    sum("total_amount").alias("revenue"),
    avg("quantity").alias("avg_items_per_order")
)

# Write
daily_sales.write.mode("overwrite") \
    .partitionBy("order_date") \
    .parquet("s3://processed/daily_sales/")

print("ETL Pipeline completed successfully!")
