# UNION vs UNIONALL IN SPARK

# Sample Data
df1 = spark.createDataFrame([(1,"A"),(2,"B")], ["id","letter"])
df2 = spark.createDataFrame([(2,"B"),(3,"C")], ["id","letter"])

# UNION (Keeps duplicates, position matters)
df1.union(df2).show()
# Output:
# +---+------+
# | id|letter|
# +---+------+
# |  1|     A|
# |  2|     B|
# |  2|     B|
# |  3|     C|
# +---+------+

# UNIONBYNAME (Matches by column name, not position)
df1.unionByName(df2).show()
# Same output as above, but safer if column order differs

# KEY POINT: In PySpark, union() = unionAll() - BOTH KEEP DUPLICATES



================================================================================

# YES CORRECT - Spark union() uses FIRST TABLE'S COLUMN NAMES for output

# Rule: Output schema ALWAYS follows first table's column names, regardless of second table's names

df1 = spark.createDataFrame([(1,"Alice")], ["id", "name"])
df2 = spark.createDataFrame([("Bob",2)], ["name", "id"])

df1.union(df2).show()
# Output columns: id, name (taken from df1, ignores df2's column names)
# +---+-----+
# | id| name|
# +---+-----+
# |  1|Alice|
# |Bob|    2|  <- Bob goes under "id", 2 goes under "name" (WRONG)
# +---+-----+


