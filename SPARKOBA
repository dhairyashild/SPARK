    StructField("id", IntegerType(), True),
    StructField("name", StringType(), True),
    StructField("_bad_data", StringType(), True) # Special column
])

df = spark.read.format("json") \
    .option("columnNameOfCorruptRecord", "_bad_data") \
    .schema(schema) \
    .load("path")

# Separate and Store
bad_df = df.filter(df._bad_data.isNotNull())
bad_df.write.parquet("s3://rejected_data/date=2026-04-22/")
